---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticuloCard from '../components/ArticuloCard.astro';
import { getCollection } from 'astro:content';

const articulos = (await getCollection('articulos'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Inicio" description="Ciensite — Divulgación científica por estudiantes mexicanos. Ciencia accesible, en español y para todos.">
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-navy text-warm-white">
      <!-- SVG decorativo de fondo: modelo atómico -->
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="400" cy="300" r="80" stroke="currentColor" stroke-width="1"/>
          <circle cx="400" cy="300" r="120" stroke="currentColor" stroke-width="0.5"/>
          <circle cx="400" cy="300" r="200" stroke="currentColor" stroke-width="0.5"/>
          <circle cx="320" cy="260" r="12" fill="currentColor"/>
          <circle cx="480" cy="340" r="12" fill="currentColor"/>
          <circle cx="400" cy="180" r="10" fill="currentColor"/>
          <line x1="320" y1="260" x2="400" y2="300" stroke="currentColor" stroke-width="0.8"/>
          <line x1="480" y1="340" x2="400" y2="300" stroke="currentColor" stroke-width="0.8"/>
          <line x1="400" y1="180" x2="400" y2="300" stroke="currentColor" stroke-width="0.8"/>
          <circle cx="150" cy="150" r="60" stroke="currentColor" stroke-width="0.5"/>
          <circle cx="150" cy="150" r="8" fill="currentColor"/>
          <circle cx="650" cy="450" r="50" stroke="currentColor" stroke-width="0.5"/>
          <circle cx="650" cy="450" r="6" fill="currentColor"/>
        </svg>
      </div>

      <div class="relative max-w-6xl mx-auto px-4 py-24 sm:py-32 lg:py-40 text-center">
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-7xl font-bold mb-6 leading-tight">
          Ciencia para <span class="text-teal">todos</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed">
          Somos un grupo de estudiantes mexicanos apasionados por la divulgación científica.
          Hacemos la ciencia accesible, interesante y en español.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/articulos/"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-teal text-navy font-semibold hover:bg-teal-dark transition-colors"
          >
            Ver artículos
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a
            href="https://instagram.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl border border-gray-500 text-gray-200 font-semibold hover:border-teal hover:text-teal transition-colors"
          >
            Seguirnos en Instagram
          </a>
        </div>
      </div>
    </section>

    <!-- Últimas publicaciones -->
    <section class="max-w-6xl mx-auto px-4 py-16 sm:py-24 fade-in">
      <div class="text-center mb-12">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy dark:text-warm-white mb-3">
          Últimas publicaciones
        </h2>
        <p class="text-gray-500 dark:text-gray-400 max-w-lg mx-auto">
          Explora nuestros artículos más recientes sobre ciencia, tecnología y medio ambiente.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articulos.map((articulo) => (
          <ArticuloCard
            title={articulo.data.title}
            description={articulo.data.description}
            date={articulo.data.date}
            category={articulo.data.category}
            coverImage={articulo.data.coverImage}
            slug={articulo.id}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <a
          href="/articulos/"
          class="inline-flex items-center gap-2 text-teal font-medium hover:underline"
        >
          Ver todos los artículos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- Sobre nosotros -->
    <section class="relative bg-gray-100 dark:bg-navy-light overflow-hidden fade-in">
      <!-- SVG molécula decorativa -->
      <div class="absolute right-0 top-0 w-64 h-64 opacity-5 dark:opacity-10">
        <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="100" cy="60" r="20" stroke="currentColor" stroke-width="2" class="text-teal"/>
          <circle cx="60" cy="140" r="16" stroke="currentColor" stroke-width="2" class="text-teal"/>
          <circle cx="150" cy="130" r="14" stroke="currentColor" stroke-width="2" class="text-teal"/>
          <circle cx="100" cy="60" r="5" fill="currentColor" class="text-teal"/>
          <circle cx="60" cy="140" r="4" fill="currentColor" class="text-teal"/>
          <circle cx="150" cy="130" r="3.5" fill="currentColor" class="text-teal"/>
          <line x1="100" y1="60" x2="60" y2="140" stroke="currentColor" stroke-width="1.5" class="text-teal"/>
          <line x1="100" y1="60" x2="150" y2="130" stroke="currentColor" stroke-width="1.5" class="text-teal"/>
        </svg>
      </div>

      <div class="relative max-w-4xl mx-auto px-4 py-16 sm:py-24 text-center">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy dark:text-warm-white mb-6">
          Sobre nosotros
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed mb-6 max-w-2xl mx-auto">
          <strong class="text-navy dark:text-warm-white">Ciensite</strong> nació de la convicción de que la ciencia debe ser un derecho, no un privilegio.
          Somos estudiantes de diversas universidades mexicanas que compartimos una misión:
          traducir el conocimiento científico a un lenguaje que todos puedan entender y disfrutar.
        </p>
        <p class="text-gray-500 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">
          Desde biología molecular hasta astrofísica, pasando por tecnología y medio ambiente,
          cubrimos los temas que están transformando nuestro mundo. Porque entender la ciencia
          es entender nuestro futuro.
        </p>
        <a
          href="/equipo/"
          class="inline-flex items-center gap-2 mt-8 text-teal font-medium hover:underline"
        >
          Conoce al equipo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- Síguenos -->
    <section class="max-w-6xl mx-auto px-4 py-16 sm:py-24 text-center fade-in">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy dark:text-warm-white mb-4">
        Síguenos
      </h2>
      <p class="text-gray-500 dark:text-gray-400 mb-10 max-w-lg mx-auto">
        Encuentra contenido científico en todas nuestras plataformas.
      </p>
      <div class="flex justify-center gap-6">
        <a
          href="https://instagram.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-2 p-6 rounded-2xl bg-white dark:bg-navy-light shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group"
          aria-label="Instagram"
        >
          <svg class="w-10 h-10 text-gray-400 group-hover:text-teal transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">Instagram</span>
        </a>
        <a
          href="https://youtube.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-2 p-6 rounded-2xl bg-white dark:bg-navy-light shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group"
          aria-label="YouTube"
        >
          <svg class="w-10 h-10 text-gray-400 group-hover:text-teal transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">YouTube</span>
        </a>
        <a
          href="https://tiktok.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-2 p-6 rounded-2xl bg-white dark:bg-navy-light shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group"
          aria-label="TikTok"
        >
          <svg class="w-10 h-10 text-gray-400 group-hover:text-teal transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">TikTok</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
