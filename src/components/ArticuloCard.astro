---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  coverImage: string;
  slug: string;
}

const { title, description, date, category, coverImage, slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Estimación de tiempo de lectura (~200 palabras por minuto)
const readTime = Math.max(1, Math.ceil(description.split(' ').length / 40));
---

<article class="group bg-white dark:bg-navy-light rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
  <a href={`/articulos/${slug}/`} class="block" aria-label={`Leer: ${title}`}>
    <div class="relative overflow-hidden">
      <img
        src={coverImage}
        alt={`Portada del artículo: ${title}`}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
      <span class="absolute top-3 left-3 px-2.5 py-1 text-xs font-semibold bg-teal text-navy rounded-full">
        {category}
      </span>
    </div>
    <div class="p-5">
      <h3 class="font-serif text-lg font-bold text-navy dark:text-warm-white mb-2 line-clamp-2 group-hover:text-teal transition-colors">
        {title}
      </h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">
        {description}
      </p>
      <div class="flex items-center justify-between text-xs text-gray-400 dark:text-gray-500">
        <time datetime={new Date(date).toISOString()}>{formattedDate}</time>
        <span>{readTime} min de lectura</span>
      </div>
    </div>
  </a>
</article>
