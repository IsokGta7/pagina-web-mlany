---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/articulos/', label: 'Artículos' },
  { href: '/multimedia/', label: 'Multimedia' },
  { href: '/equipo/', label: 'Equipo' },
  { href: '/contacto/', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 bg-warm-white/80 dark:bg-navy/80 backdrop-blur-lg border-b border-gray-200/50 dark:border-gray-700/50">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegación principal">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Ciensite — Inicio">
      <svg class="w-8 h-8 text-teal" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="16" cy="16" r="4" fill="currentColor"/>
        <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2" fill="none" opacity="0.3"/>
        <circle cx="16" cy="4" r="2.5" fill="currentColor"/>
        <circle cx="27" cy="22" r="2.5" fill="currentColor"/>
        <circle cx="5" cy="22" r="2.5" fill="currentColor"/>
      </svg>
      <span class="font-serif text-xl font-bold text-navy dark:text-warm-white group-hover:text-teal transition-colors">
        Ciensite
      </span>
    </a>

    <!-- Navegación escritorio -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <li>
            <a
              href={href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                isActive
                  ? 'text-teal bg-teal/10'
                  : 'text-gray-600 dark:text-gray-300 hover:text-navy dark:hover:text-warm-white hover:bg-gray-100 dark:hover:bg-navy-light',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Controles derecho -->
    <div class="flex items-center gap-2">
      <!-- Toggle modo oscuro -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-navy-light transition-colors"
        aria-label="Cambiar tema"
        type="button"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/></svg>
        <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
      </button>

      <!-- Hamburguesa móvil -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-navy-light transition-colors"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        type="button"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-gray-200/50 dark:border-gray-700/50 bg-warm-white dark:bg-navy">
    <ul class="px-4 py-3 space-y-1">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <li>
            <a
              href={href}
              class:list={[
                'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                isActive
                  ? 'text-teal bg-teal/10'
                  : 'text-gray-600 dark:text-gray-300 hover:text-navy dark:hover:text-warm-white hover:bg-gray-100 dark:hover:bg-navy-light',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script is:inline>
  // Toggle tema oscuro
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Menú móvil
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
