---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticuloCard from '../components/ArticuloCard.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  coverImage: string;
  author: string;
  slug: string;
}

const { title, description, date, category, coverImage, author, slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Artículos relacionados (misma categoría, excluyendo el actual)
const allArticulos = await getCollection('articulos');
const related = allArticulos
  .filter((a) => a.data.category === category && a.id !== slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

// URL para compartir
const shareUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);
---

<BaseLayout title={title} description={description} ogImage={coverImage}>
  <Header />

  <main class="flex-1">
    <article class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
      <!-- Encabezado del artículo -->
      <header class="mb-8">
        <span
          class="inline-block px-3 py-1 text-sm font-medium bg-teal/10 text-teal rounded-full mb-4"
        >
          {category}
        </span>
        <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-navy dark:text-warm-white leading-tight mb-4">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-gray-500 dark:text-gray-400 text-sm">
          <span>Por <strong class="text-gray-700 dark:text-gray-200">{author}</strong></span>
          <span>•</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </div>
      </header>

      <!-- Imagen de portada -->
      <img
        src={coverImage}
        alt={`Imagen de portada: ${title}`}
        class="w-full h-64 sm:h-80 lg:h-96 object-cover rounded-2xl mb-10"
        loading="eager"
      />

      <!-- Contenido del artículo -->
      <div class="prose prose-lg max-w-none dark:prose-invert prose-headings:font-serif prose-a:text-teal prose-a:no-underline hover:prose-a:underline">
        <slot />
      </div>

      <!-- Botones de compartir -->
      <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-4">Compartir este artículo</p>
        <div class="flex gap-3">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 dark:bg-navy-light text-gray-700 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-sm"
            aria-label="Compartir en Twitter"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter / X
          </a>
          <a
            href={`https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 dark:bg-navy-light text-gray-700 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-sm"
            aria-label="Compartir en WhatsApp"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <button
            id="copy-link-btn"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 dark:bg-navy-light text-gray-700 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-sm cursor-pointer"
            aria-label="Copiar enlace"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            <span id="copy-link-text">Copiar enlace</span>
          </button>
        </div>
      </div>
    </article>

    <!-- Artículos relacionados -->
    {related.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 pb-16">
        <h2 class="font-serif text-2xl font-bold text-navy dark:text-warm-white mb-8">
          Artículos relacionados
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {related.map((articulo) => (
            <ArticuloCard
              title={articulo.data.title}
              description={articulo.data.description}
              date={articulo.data.date}
              category={articulo.data.category}
              coverImage={articulo.data.coverImage}
              slug={articulo.id}
            />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />

  <script is:inline>
    document.getElementById('copy-link-btn')?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = document.getElementById('copy-link-text');
        if (textEl) {
          textEl.textContent = '¡Copiado!';
          setTimeout(() => { textEl.textContent = 'Copiar enlace'; }, 2000);
        }
      } catch {
        // Fallback silencioso
      }
    });
  </script>
</BaseLayout>
